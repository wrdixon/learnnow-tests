{
  "chapter": 1,
  "title": "Introductions",
  "description": "Greetings, introductions, nationalities & basic word order",
  "subchapters": [
    { "id": "1A", "title": "Alex", "theme": "Basic greeting and asking names" },
    { "id": "1B", "title": "Benjamin", "theme": "Formal greeting, nice to meet you" },
    { "id": "1C", "title": "Cecilie", "theme": "Nationality, yes/no questions" },
    { "id": "1D", "title": "Dina", "theme": "Where are you from?" }
  ],
  "grammar": [
    {
      "topic": "Word order in main clauses",
      "rule": "Subject – Verb – Rest of sentence",
      "examples": [
        { "no": "Jeg heter Alex.", "en": "My name is Alex." },
        { "no": "Jeg kommer fra Frankrike.", "en": "I come from France." }
      ]
    },
    {
      "topic": "Questions with question words",
      "rule": "Question word – Verb – Subject – Rest",
      "examples": [
        { "no": "Hva heter du?", "en": "What is your name?" },
        { "no": "Hvor kommer du fra?", "en": "Where do you come from?" }
      ]
    },
    {
      "topic": "Yes/no questions",
      "rule": "Verb comes first (no question word)",
      "examples": [
        { "no": "Er du norsk?", "en": "Are you Norwegian?" }
      ]
    },
    {
      "topic": "Present tense verbs",
      "rule": "Most verbs end in -r in present tense",
      "examples": [
        { "no": "heter", "en": "am/is/are named" },
        { "no": "kommer", "en": "come(s)" },
        { "no": "er", "en": "am/is/are (irregular)" }
      ]
    },
    {
      "topic": "Question words",
      "rule": "The h in hv- words is silent",
      "examples": [
        { "no": "hva", "en": "what" },
        { "no": "hvem", "en": "who" },
        { "no": "hvor", "en": "where / how" },
        { "no": "hvordan", "en": "how" }
      ]
    },
    {
      "topic": "Nationalities",
      "rule": "Country → adjective/nationality → person → language",
      "examples": [
        { "no": "Norge – norsk – en nordmann – norsk", "en": "Norway – Norwegian – a Norwegian – Norwegian" },
        { "no": "Frankrike – fransk – en franskmann – fransk", "en": "France – French – a Frenchman – French" },
        { "no": "England – engelsk – en engelskmann – engelsk", "en": "England – English – an Englishman – English" }
      ]
    }
  ],
  "vocabulary": [
    { "no": "du", "en": "you", "type": "pronoun", "sub": "1A" },
    { "no": "hei", "en": "hi", "type": "greeting", "sub": "1A" },
    { "no": "heter", "en": "am/is/are named", "type": "verb", "sub": "1A", "infinitive": "å hete" },
    { "no": "hva", "en": "what", "type": "question word", "sub": "1A" },
    { "no": "jeg", "en": "I", "type": "pronoun", "sub": "1A" },
    { "no": "dag", "en": "a day", "article": "en", "type": "noun", "sub": "1B", "inflection": "dagen, dager, dagene" },
    { "no": "god", "en": "good", "type": "adjective", "sub": "1B", "inflection": "godt, gode" },
    { "no": "hete", "en": "to be named", "type": "verb", "sub": "1B", "article": "å", "inflection": "heter, het, har hett" },
    { "no": "hilse", "en": "to greet", "type": "verb", "sub": "1B", "article": "å", "inflection": "hilser, hilste, har hilst" },
    { "no": "hyggelig", "en": "nice, pleasant", "type": "adjective", "sub": "1B", "inflection": "hyggelig, hyggelige" },
    { "no": "på", "en": "on, at", "type": "preposition", "sub": "1B" },
    { "no": "å", "en": "to (infinitive marker)", "type": "particle", "sub": "1B" },
    { "no": "er", "en": "am, are, is", "type": "verb", "sub": "1C", "infinitive": "å være" },
    { "no": "hallo", "en": "hello", "type": "greeting", "sub": "1C" },
    { "no": "norsk", "en": "Norwegian", "type": "adjective", "sub": "1C", "inflection": "norsk, norske" },
    { "no": "fra", "en": "from", "type": "preposition", "sub": "1D" },
    { "no": "Frankrike", "en": "France", "type": "noun", "sub": "1D" },
    { "no": "hvor", "en": "where", "type": "question word", "sub": "1D" },
    { "no": "kommer", "en": "come(s)", "type": "verb", "sub": "1D", "infinitive": "å komme" }
  ],
  "dialogues": [
    { "sub": "1A", "no": "Hei! Jeg heter Alex. Hva heter du?", "context": "Alex introduces himself" },
    { "sub": "1B", "no": "God dag! Jeg heter Benjamin Vidal. Hyggelig å hilse på deg!", "context": "Ben introduces himself formally" },
    { "sub": "1C", "no": "Hallo! Jeg heter Cecilie Hansen Vidal. Jeg er norsk. Er du norsk?", "context": "Cecilie states her nationality" },
    { "sub": "1D", "no": "Hei! Jeg heter Dina. Jeg kommer fra Frankrike. Hvor kommer du fra?", "context": "Dina says where she is from" }
  ],
  "phrases": [
