{
  "chapter": 2,
  "title": "Fra Paris til Oslo",
  "description": "Travel, family, pronouns, present tense verbs, noun genders & negation",
  "subchapters": [
    { "id": "2A", "title": "Fra Paris til Oslo", "theme": "Travelling by plane with family" },
    { "id": "2B", "title": "På Gardermoen", "theme": "At the airport, meeting people" },
    { "id": "2C", "title": "Passkontroll", "theme": "Passport control, checking documents" },
    { "id": "2D", "title": "Hei, pappa!", "theme": "Reuniting with dad, how are you" }
  ],
  "grammar": [
    {
      "topic": "Personal pronouns (subject form)",
      "rule": "jeg, du, han, hun, det/den, vi, dere, de",
      "examples": [
        { "no": "Jeg kommer fra Norge.", "en": "I come from Norway." },
        { "no": "Han er fransk.", "en": "He is French." },
        { "no": "Vi reiser sammen.", "en": "We travel together." },
        { "no": "De bor i Fjordvik.", "en": "They live in Fjordvik." }
      ]
    },
    {
      "topic": "Verbs: infinitive and present tense",
      "rule": "Add -r to the infinitive to form present tense. Same form for all pronouns.",
      "examples": [
        { "no": "å komme → kommer", "en": "to come → come(s)" },
        { "no": "å sitte → sitter", "en": "to sit → sit(s)" },
        { "no": "å snakke → snakker", "en": "to speak → speak(s)" }
      ]
    },
    {
      "topic": "Irregular present tense",
      "rule": "Some verbs are irregular: å være → er, å gjøre → gjør",
      "examples": [
        { "no": "Jeg er norsk.", "en": "I am Norwegian." },
        { "no": "Hva gjør du?", "en": "What do you do?" }
      ]
    },
    {
      "topic": "Noun genders",
      "rule": "Three genders: masculine (en), feminine (ei), neuter (et). Feminine can also use 'en'.",
      "examples": [
        { "no": "en gutt", "en": "a boy (masculine)" },
        { "no": "ei jente", "en": "a girl (feminine)" },
        { "no": "et fly", "en": "an airplane (neuter)" }
      ]
    },
    {
      "topic": "Word order with time/place first",
      "rule": "Verb is always second element, even when sentence starts with time/place word (inversion)",
      "examples": [
        { "no": "Nå reiser Alex til Norge.", "en": "Now Alex is travelling to Norway." },
        { "no": "Der venter pappa.", "en": "Dad is waiting there." }
      ]
    },
    {
      "topic": "Negation",
      "rule": "'ikke' (not) comes after the verb in main clauses",
      "examples": [
        { "no": "Jeg reiser ikke til Paris.", "en": "I don't travel to Paris." },
        { "no": "Han snakker ikke norsk.", "en": "He doesn't speak Norwegian." }
      ]
    },
    {
      "topic": "Ongoing actions: stå/sitte/ligge + verb",
      "rule": "Use position verbs + og + present tense for ongoing actions (like English -ing)",
      "examples": [
        { "no": "Benjamin står og venter.", "en": "Benjamin is waiting." },
        { "no": "Alex sitter og snakker med ei dame.", "en": "Alex is talking to a woman." }
      ]
    },
    {
      "topic": "Conjunctions",
      "rule": "'og' (and) and 'men' (but) connect sentences",
      "examples": [
        { "no": "De ser pappa, og Dina roper.", "en": "They see dad, and Dina shouts." },
        { "no": "Det går bra, men det er ei lang reise.", "en": "I'm fine, but it's a long journey." }
      ]
    },
    {
      "topic": "Prepositions: i or på",
      "rule": "'i' for continents, countries, cities. 'på' for mountains, islands, places, parts of a city.",
      "examples": [
        { "no": "i Norge, i Oslo", "en": "in Norway, in Oslo" },
        { "no": "på Gardermoen, på Mallorca", "en": "at Gardermoen, on Mallorca" }
      ]
    }
  ],
