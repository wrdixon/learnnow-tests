{
  "chapter": 3,
  "title": "A New Home",
  "description": "Furniture, days, time expressions, asking for information & home vocabulary",
  "subchapters": [
    { "id": "3A", "title": "Alex våkner i Fjordvik", "theme": "Morning routine, waiting for the moving truck" },
    { "id": "3B", "title": "Flyttebilen kommer", "theme": "The moving truck arrives, meeting the neighbour" },
    { "id": "3C", "title": "Hjemme", "theme": "Describing the apartment, rooms and furniture" },
    { "id": "3D", "title": "Dinas rom", "theme": "Dina's room, clothing, taking photos" },
    { "id": "3E", "title": "Extras", "theme": "Days of the week, furniture, kitchen, buildings, foreigner" }
  ],
  "grammar": [
    {
      "topic": "Personal pronouns — object form",
      "rule": "Object pronouns: meg (me), deg (you), ham/han (him), henne (her), det/den (it), oss (us), dere (you pl.), dem (them)",
      "examples": [
        { "no": "Du kan kalle meg Ben.", "en": "You can call me Ben." },
        { "no": "Hyggelig å møte deg.", "en": "Nice to meet you." },
        { "no": "Kan vi besøke dem snart?", "en": "Can we visit them soon?" }
      ]
    },
    {
      "topic": "Auxiliary verbs + infinitive",
      "rule": "Auxiliary verbs (skal, vil, kan, må, bør) are followed by the infinitive WITHOUT 'å'",
      "examples": [
        { "no": "Dina skal gå på skolen.", "en": "Dina is going to go to school." },
        { "no": "Mormor vil ha besøk.", "en": "Grandma wants to have visitors." },
        { "no": "Han må finne en venn.", "en": "He must find a friend." },
        { "no": "Kan vi besøke dem?", "en": "Can we visit them?" }
      ]
    },
    {
      "topic": "Nouns — definite form singular",
      "rule": "No article in front; add suffix: masculine -en, feminine -a, neuter -et. If noun ends in -e, just add -n/-t (masc/neut) or replace -e with -a (fem).",
      "examples": [
        { "no": "en stol → stolen", "en": "a chair → the chair" },
        { "no": "ei dør → døra", "en": "a door → the door" },
        { "no": "et bord → bordet", "en": "a table → the table" },
        { "no": "en familie → familien", "en": "a family → the family" },
        { "no": "ei stue → stua", "en": "a living room → the living room" }
      ]
    },
    {
      "topic": "Nouns — plural forms",
      "rule": "Indefinite plural: add -(e)r. If noun ends in -e, just add -r. Short neuter words: no ending. Definite plural: add -(e)ne.",
      "examples": [
        { "no": "en stol → stoler → stolene", "en": "a chair → chairs → the chairs" },
        { "no": "ei dør → dører → dørene", "en": "a door → doors → the doors" },
        { "no": "et hus → hus → husene", "en": "a house → houses → the houses" }
      ]
    },
    {
      "topic": "Genitive (possessives)",
      "rule": "Add -s to owner (no apostrophe): Dinas rom. Or use 'til': Rommet til Dina. With -s the owned noun is indefinite; with 'til' it is definite.",
      "examples": [
        { "no": "Dinas rom", "en": "Dina's room" },
        { "no": "Rommet til Dina", "en": "The room of Dina / Dina's room" }
      ]
    },
    {
      "topic": "Det er (existential 'there is/are')",
      "rule": "'Det er' = 'there is/there are'. Det does not change for gender or number. With inversion, verb comes before det.",
      "examples": [
        { "no": "Det er fire stoler i stua.", "en": "There are four chairs in the living room." },
        { "no": "På Dinas rom er det ei seng.", "en": "In Dina's room there is a bed." }
      ]
    },
    {
      "topic": "Den/det as pronoun (it)",
      "rule": "'Den' replaces masculine and feminine nouns. 'Det' replaces neuter nouns.",
      "examples": [
        { "no": "De har en sofa. Den er i stua.", "en": "They have a sofa. It is in the living room." },
        { "no": "Dina har et skap. Det har tre hyller.", "en": "Dina has a cupboard. It has three shelves." }
      ]
    }
  ],
