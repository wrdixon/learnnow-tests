  "dialogues": [
    {
      "sub": "3A",
      "title": "Alex våkner i Fjordvik",
      "intro": "Det er mandag morgen. Alex ligger på en madrass og tenker. Han er ikke i Paris, han er i Fjordvik i Norge. Her skal de bo. Han skal gå i barnehagen her. Dina skal gå på skolen. Mamma og pappa skal jobbe.",
      "lines": [
        { "speaker": "Mamma", "text": "God morgen, Alex! Er du våken?" },
        { "speaker": "Alex", "text": "Hei, mamma. Hva skal vi gjøre i dag?" },
        { "speaker": "Mamma", "text": "Vi skal være hjemme. Vi skal være sammen, du og Dina og pappa og jeg." },
        { "speaker": "Alex", "text": "Men hva skal vi gjøre?" },
        { "speaker": "Mamma", "text": "Vi venter på en flyttebil. Men nå skal vi spise frokost. Kommer du?" },
        { "speaker": "Alex", "text": "Ja, jeg kommer." },
        { "speaker": "Mamma", "text": "Dina! Ben! Nå er det frokost." }
      ],
      "outro": "De sitter rundt bordet og spiser frokost sammen. Det er hyggelig. Dina sier noe morsomt. Pappa ler, og mamma smiler. Alex sitter og tenker. Han er i Norge nå. Han kjenner bare mamma, pappa og Dina her. Han må finne en venn."
    },
    {
      "sub": "3B",
      "title": "Flyttebilen kommer",
      "intro": "Familien Vidal bor i et hus med fire madrasser, fire stoler og ett bord. Det er alt. De venter på en flyttebil med møbler fra Frankrike. Bilen skal komme på mandag. Mandag formiddag stopper en lastebil utenfor huset. Benjamin går ut og snakker med sjåføren.",
      "lines": [
        { "speaker": "Ben", "text": "Hei!" },
        { "speaker": "Sjåfør", "text": "Hei, vi er fra Drammen flyttebyrå. Er dette Osloveien 24 A?" },
        { "speaker": "Ben", "text": "Ja, det er riktig adresse." },
        { "speaker": "Sjåfør", "text": "Er du Benjamin Vidal?" },
        { "speaker": "Ben", "text": "Ja, det er riktig!" },
        { "speaker": "Sjåfør", "text": "Fint! Vi skal bære inn møblene." }
      ],
      "outro": "To menn kommer ut av lastebilen. Benjamin roper på Cecilie og Alex. De kommer ut og hjelper mennene. Etter et kvarter kommer en nabo.",
      "lines2": [
        { "speaker": "Hans", "text": "Hei! Jeg er naboen din. Jeg heter Hans Olsen." },
        { "speaker": "Ben", "text": "Jeg heter Benjamin Vidal, men du kan kalle meg Ben." },
        { "speaker": "Hans", "text": "Hyggelig å møte deg, Ben." },
        { "speaker": "Ben", "text": "Her er familien min. Kona heter Cecilie." },
        { "speaker": "Hans", "text": "God dag, jeg bor i nabohuset sammen med Anne." },
        { "speaker": "Cecilie", "text": "God dag!" },
        { "speaker": "Ben", "text": "Og her er Alex. Vi har også ei jente, hun heter Dina." },
        { "speaker": "Hans", "text": "Hyggelig å hilse på dere!" }
      ]
    },
    {
      "sub": "3C",
      "title": "Hjemme",
      "intro": "Det er tirsdag ettermiddag. Cecilie og Alex er hjemme. Cecilie går rundt i leiligheten. Hun liker den. Den er stor, med gang, kjøkken, bad, stue og tre soverom. På kjøkkenet er det en benk med komfyr og oppvaskmaskin. I hjørnet står et kjøleskap. Det er også et spisebord og seks stoler der. På badet er det to vasker, en dusj og en vaskemaskin. Møblene i stua er på plass. Der står et salongbord, en sofa og to lenestoler, men de må kjøpe en TV.",
      "lines": [
        { "speaker": "Alex", "text": "Mamma, kan vi gå ut på balkongen?" },
        { "speaker": "Cecilie", "text": "Ja, det er greit." },
        { "speaker": "Alex", "text": "Hvor bor mormor og morfar?" },
        { "speaker": "Cecilie", "text": "Kan du se husene der borte?" },
        { "speaker": "Alex", "text": "Ja." },
        { "speaker": "Cecilie", "text": "Der bor mormor og morfar." },
        { "speaker": "Alex", "text": "Kan vi besøke dem snart?" },
        { "speaker": "Cecilie", "text": "Du kan ringe til mormor nå og spørre. Her er telefonen." },
        { "speaker": "Alex", "text": "Hei, mormor! Det er Alex. Kan vi besøke dere?" }
      ],
      "outro": "Mormor vil ha besøk nå. Alex hopper i trappa og løper til bilen. Den står i garasjen. Han skal besøke mormor og morfar."
    },
    {
      "sub": "3D",
      "title": "Dinas rom",
      "intro": "Dina sitter på senga og tar bilder av rommet. Det er tirsdag kveld, og hun er alene. Vennene til Dina er i Frankrike. Men de er på Facebook. Snart kan de se bilder fra Dinas rom i Norge.",
      "lines": [],
      "outro": "Dina hører på musikk. Hun har et skrivebord og en stol. Hun har også en sofa, et bord og en lenestol, og ved vinduet står en kommode. På veggen er det bilder. Mellom døra og senga er det et klesskap. Det har ei hylle for bluser og T-skjorter, ei for bukser og skjørt, og ei for undertøy. I skapet er det også jakker og sko. Dina bytter bluse og går på badet. Hun står foran speilet og ordner håret og tar på sminke. Så henter hun kameraet, smiler og tar et bilde i speilet. Det blir kjempefint! Snart kan vennene i Frankrike se bilder av Dina i Norge."
    }
