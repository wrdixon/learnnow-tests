  "phrases": [
    { "no": "Nå skal det bli godt med frokost.", "en": "Now it will be nice with breakfast.", "sub": "6A" },
    { "no": "Så snill du er!", "en": "How kind you are!", "sub": "6A" },
    { "no": "Kan du ta denne koppen?", "en": "Can you take this cup?", "sub": "6A" },
    { "no": "Det er for tidlig.", "en": "It is too early.", "sub": "6A" },
    { "no": "Jeg vil sove.", "en": "I want to sleep.", "sub": "6A" },
    { "no": "Skal du ikke være med?", "en": "Aren't you coming along?", "sub": "6A" },
    { "no": "Her er det kjempekoselig.", "en": "It is really cosy here.", "sub": "6B" },
    { "no": "Se! Det er salg!", "en": "Look! There is a sale!", "sub": "6B" },
    { "no": "Vi har mange gode tilbud i dag.", "en": "We have many good offers today.", "sub": "6C" },
    { "no": "Hva koster de?", "en": "How much do they cost?", "sub": "6C" },
    { "no": "Hva synes du om disse skoene?", "en": "What do you think about these shoes?", "sub": "6C" },
    { "no": "Her er kvitteringen.", "en": "Here is the receipt.", "sub": "6C" },
    { "no": "Jeg er sulten og tørst.", "en": "I am hungry and thirsty.", "sub": "6D" },
    { "no": "Det er en god idé.", "en": "That is a good idea.", "sub": "6D" },
    { "no": "Jeg har ikke nok penger.", "en": "I don't have enough money.", "sub": "6D" },
    { "no": "Kan vi betale med kort?", "en": "Can we pay by card?", "sub": "6D" },
    { "no": "Takk skal du ha.", "en": "Thank you.", "sub": "6D" }
  ],
  "dialogues": [
    {
      "sub": "6A",
      "title": "Frokost",
      "intro": "Det er lørdag morgen. Alex og pappa er på badet. Pappa vasker ham, og Alex tørker seg. Etterpå vasker pappa seg og barberer seg. De kler på seg og går ned på kjøkkenet.",
      "lines": [
        { "speaker": "Mamma", "text": "God morgen, Alex. Nå skal det bli godt med frokost." },
        { "speaker": "Alex", "text": "Hei mamma, skal jeg hjelpe deg? Jeg kan dekke på bordet." },
        { "speaker": "Mamma", "text": "Så snill du er! Kan du ta denne koppen? Jeg tar disse glassene. Etterpå kan du ta de knivene der borte." },
        { "speaker": "Alex", "text": "OK, kopp og kniver." },
        { "speaker": "Mamma", "text": "Vi må ha tallerkener også. Her er noen røde og noen gule tallerkener. Liker du disse?" },
        { "speaker": "Alex", "text": "Ja, de er fine." }
      ],
      "outro": "Alex og pappa henter mat i kjøleskapet. Først finner de smør, melk og jus, syltetøy, tomater, skinke og ost. Så skjærer pappa opp grovbrød og loff. Mamma koker vann og lager kaffe og te. Pappa vekker Dina. Fem minutter seinere setter hun seg ved bordet. Familien er sammen, og Alex er glad."
    },
    {
      "sub": "6B",
      "title": "I byen",
      "intro": "Ben og Alex setter seg i bilen. Nå har de en ny TV. Den er stor og moderne. De kjører til sentrum og finner Dina og Cecilie. Nå skal de se på byen sammen.",
      "lines": [
        { "speaker": "Alex", "text": "Jeg gleder meg til å se på barne-TV. Skal vi kjøre hjem med TV-en?" },
        { "speaker": "Ben", "text": "Nei, nå må vi til byen og finne mamma og Dina. Du må vente til i kveld." },
        { "speaker": "Dina", "text": "Her er det kjempekoselig. Etterpå vil jeg spise på den kaféen ved apoteket der borte." },
        { "speaker": "Ben", "text": "Ja vel, men først vil jeg vise dere mer av byen. Nå kan vi gå til gågata." },
        { "speaker": "Dina", "text": "Se! Det er salg!" },
        { "speaker": "Cecilie", "text": "Det er morsomt å se på byen. Men jeg trenger ei ny jakke. Kom, Dina!" }
      ],
      "outro": "I gågata er det mange gamle hus med forskjellige butikker og et nytt, moderne kjøpesenter."
    },
    {
      "sub": "6C",
      "title": "Salg",
      "intro": "Familien er inne på kjøpesenteret i gågata. Cecilie og Dina går mot klesbutikkene. De finner en liten skobutikk med salg.",
      "lines": [
        { "speaker": "Ekspeditør", "text": "Hei, kan jeg hjelpe dere?" },
