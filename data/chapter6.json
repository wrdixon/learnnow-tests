{
  "chapter": 6,
  "title": "A Trip to Town",
  "description": "Breakfast, shopping, clothes, café, demonstrative pronouns & adjective patterns",
  "subchapters": [
    { "id": "6A", "title": "Frokost", "theme": "Saturday breakfast, setting the table" },
    { "id": "6B", "title": "I byen", "theme": "Exploring the town, shops and sights" },
    { "id": "6C", "title": "Salg", "theme": "Shopping for shoes and clothes, prices" },
    { "id": "6D", "title": "På kafé", "theme": "Ordering at a café, food and drink" },
    { "id": "6E", "title": "Extras", "theme": "Bathroom, shopping centre, clothes, spare time" }
  ],
  "grammar": [
    {
      "topic": "Demonstrative pronouns",
      "rule": "denne/dette/disse (this/these, close) and den/det/de (that/those, remote). The noun takes definite form after demonstratives.",
      "examples": [
        { "no": "denne koppen (this cup) / den koppen (that cup)", "en": "denne = masc/fem, dette = neuter, disse = plural" },
        { "no": "Kan du ta disse glassene?", "en": "Can you take these glasses?" },
        { "no": "Jeg vil spise på den kaféen der borte.", "en": "I want to eat at that café over there." }
      ]
    },
    {
      "topic": "Adjective patterns — exceptions",
      "rule": "Adjectives ending in -ig, -sk (nationality), -isk, -e take NO -t in neuter. Double consonant drops one before -t. 'liten' and 'annen' are irregular.",
      "examples": [
        { "no": "et billig bord (not billigt)", "en": "-ig adjectives: no -t in neuter" },
        { "no": "et tysk bord (not tyskt)", "en": "-sk nationality adjectives: no -t in neuter" },
        { "no": "et grønt bord (grønn → grønt)", "en": "Double consonant drops one before -t" },
        { "no": "en liten bil / ei lita bok / et lite bord / små biler", "en": "'liten' is irregular in all forms" }
      ]
    },
    {
      "topic": "Auxiliary verbs without main verb (motion)",
      "rule": "When an auxiliary verb is followed by a direction, the motion verb (gå/dra/reise) can be dropped.",
      "examples": [
        { "no": "Hun skal til Paris. (= Hun skal reise til Paris.)", "en": "She is going to Paris." },
        { "no": "Nå må de tilbake. (= Nå må de gå tilbake.)", "en": "Now they must go back." }
      ]
    },
    {
      "topic": "for å + infinitive",
      "rule": "'for å' means 'in order to' before an infinitive.",
      "examples": [
        { "no": "Dina går til disken for å bestille.", "en": "Dina goes to the counter in order to order." },
        { "no": "De kjører for å kjøpe en TV.", "en": "They drive in order to buy a TV." }
      ]
    }
  ],
