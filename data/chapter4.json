  "dialogues": [
    {
      "sub": "4A",
      "title": "Hos mormor og morfar",
      "intro": "Alex og mamma kjører til mormor og morfar. Mamma stopper foran huset. Alex løper opp trappa. Der står mormor og venter på ham. Hun løfter Alex og gir ham en klem.",
      "lines": [
        { "speaker": "Mormor", "text": "Hei, Alex. Så koselig å se deg her! Kom inn!" },
        { "speaker": "Alex", "text": "Hei mormor. Er morfar hjemme?" },
        { "speaker": "Mormor", "text": "Ja, men nå er han på butikken. Han skal kjøpe is og brus til deg. Du liker is, ikke sant?" }
      ],
      "outro": "Alex smiler. Så tar han av skoene og løper inn i stua. De sitter rundt salongbordet i stua og drikker kaffe og spiser is. Morfar spør om Alex liker Fjordvik. Alex sier ja, men han har ingen venner her. Morfar sier at han skal begynne i barnehagen. Alex sier det blir gøy, og spør om de skal spille fotball."
    },
    {
      "sub": "4B",
      "title": "Bens morgen",
      "intro": "Ben står opp klokka halv sju. Kvart på sju dusjer han. Han drikker kaffe og spiser frokost klokka sju. Kvart over sju vekker han Dina, og ti på halv åtte lager han frokost til Alex. Han må være på jobb klokka åtte, men kontoret er like i nærheten.",
      "lines": [
        { "speaker": "Hans", "text": "God morgen!" },
        { "speaker": "Ben", "text": "Hei, Hans! Takk for sist!" },
        { "speaker": "Hans", "text": "I like måte. Går det bra?" },
        { "speaker": "Ben", "text": "Ja, nå er møblene på plass." },
        { "speaker": "Hans", "text": "Hvordan går det med familien?" },
        { "speaker": "Ben", "text": "Bra! Cecilie skal snart begynne på sykehuset. Barna begynner på skolen og i barnehagen." },
        { "speaker": "Hans", "text": "Fint! Ha det bra! Jeg må kjøre." },
        { "speaker": "Ben", "text": "Ha det!" }
      ],
      "outro": "Ben liker nabolaget. Det er fint å bo nær jobben. Han liker å gå. Fem minutter på åtte er han allerede på kontoret."
    },
    {
      "sub": "4C",
      "title": "Cecilie sender en pakke",
      "intro": "Det er tiende august. Bens mor har fødselsdag snart, og Cecilie skal sende en gave til henne. Hun må ikke få den for seint. Cecilie ringer på døra til Hans og Anne Olsen. Anne åpner.",
      "lines": [
        { "speaker": "Cecilie", "text": "Hei! Jeg heter Cecilie Vidal. Jeg bor i huset ved siden av dere." },
        { "speaker": "Anne", "text": "Hyggelig å hilse på deg! Jeg er Anne Olsen." },
        { "speaker": "Cecilie", "text": "Jeg må sende en pakke med posten. Er det et postkontor i nærheten?" },
        { "speaker": "Anne", "text": "Ja, det er et postkontor i butikken." },
        { "speaker": "Cecilie", "text": "Hvilken butikk?" },
        { "speaker": "Anne", "text": "Matbua." },
        { "speaker": "Cecilie", "text": "Hvor er den?" },
        { "speaker": "Anne", "text": "Den ligger rett ved veikrysset." },
        { "speaker": "Cecilie", "text": "Hvilket kryss mener du?" },
        { "speaker": "Anne", "text": "Jeg mener lyskrysset ved bensinstasjonen." },
        { "speaker": "Cecilie", "text": "Å ja. Tusen takk for hjelpen!" },
        { "speaker": "Anne", "text": "Jeg skal straks kjøre i samme retning. Vil du kjøre med meg?" },
        { "speaker": "Cecilie", "text": "Ja gjerne, så hyggelig av deg! Jeg skal bare hente pakken." }
      ],
      "outro": "Anne kjører Cecilie til Matbua. Det tar bare fem minutter. Cecilie takker for turen. Snart er pakken på vei til Frankrike."
    },
    {
      "sub": "4D",
      "title": "Veien til skolen",
      "intro": "Det er onsdag kveld. Mandag er første dag på skolen. Dina skal begynne i niende klasse på ungdomsskolen.",
      "lines": [
        { "speaker": "Dina", "text": "Pappa, jeg må lære veien til skolen. Hvor ligger den?" },
