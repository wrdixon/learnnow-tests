{
  "chapter": 4,
  "title": "The Neighbourhood",
  "description": "Asking for directions, time expressions, family words & the imperative",
  "subchapters": [
    { "id": "4A", "title": "Hos mormor og morfar", "theme": "Visiting grandparents, ice cream and football" },
    { "id": "4B", "title": "Bens morgen", "theme": "Ben's morning routine, telling the time" },
    { "id": "4C", "title": "Cecilie sender en pakke", "theme": "Sending a package, asking for directions" },
    { "id": "4D", "title": "Veien til skolen", "theme": "Directions to school, ordinals" },
    { "id": "4E", "title": "Extras", "theme": "Family words, telling the time, ordinals, dates" }
  ],
  "grammar": [
    {
      "topic": "Imperative form",
      "rule": "Remove the infinitive -e to form the imperative. Verbs ending in -mme have one -m. Short verbs (one syllable) keep the same form.",
      "examples": [
        { "no": "å kjøpe → Kjøp!", "en": "to buy → Buy!" },
        { "no": "å stoppe → Stopp!", "en": "to stop → Stop!" },
        { "no": "å komme → Kom!", "en": "to come → Come!" },
        { "no": "å se → Se!", "en": "to see → See!" }
      ]
    },
    {
      "topic": "Question word: hvilken/hvilket/hvilke",
      "rule": "'Hvilken' (which) agrees with gender and number: hvilken (masc/fem), hvilket (neuter), hvilke (plural).",
      "examples": [
        { "no": "Hvilken pakke sender du?", "en": "Which package are you sending? (en pakke)" },
        { "no": "Hvilket bord vil du ha?", "en": "Which table do you want? (et bord)" },
        { "no": "Hvilke aviser leser du?", "en": "Which newspapers do you read? (plural)" }
      ]
    },
    {
      "topic": "Telling the time",
      "rule": "'Hva er klokka?' = What time is it? Use 'over' for past, 'på' for to, 'halv' for half (refers to the NEXT hour). 'Kvart' = quarter.",
      "examples": [
        { "no": "Klokka er kvart over tolv.", "en": "It is quarter past twelve (12:15)." },
        { "no": "Klokka er halv ett.", "en": "It is half past twelve (12:30) — literally 'half one'." },
        { "no": "Klokka er kvart på to.", "en": "It is quarter to two (13:45)." },
        { "no": "Klokka er ti på halv åtte.", "en": "It is twenty past seven (7:20) — literally 'ten to half eight'." }
      ]
    },
    {
      "topic": "Dates",
      "rule": "Day-month-year order. Day is an ordinal number, no capital on the month, no preposition before a date.",
      "examples": [
        { "no": "første september tjuetretten", "en": "1 September 2013" },
        { "no": "Cecilie sender en pakke tiende august.", "en": "Cecilie sends a package on the tenth of August." }
      ]
    }
  ],
